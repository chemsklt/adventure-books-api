        {
          "name": "List all books",
          "request": {
            "method": "GET",
            "header": [],
            "description": "",
            "url": {
              "raw": "{{baseUrl}}/books",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test(\"Response has content array\", function () {",
                  "    pm.expect(json).to.have.property(\"content\");",
                  "    pm.expect(json.content).to.be.an(\"array\");",
                  "});",
                  "pm.test(\"Response has totalElements\", function () {",
                  "    pm.expect(json).to.have.property(\"totalElements\");",
                  "});"
